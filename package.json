{
  "name": "ws",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "preview": "npm run build && next start --hostname 0.0.0.0",
    "lint": "eslint",
    "db:start": "prisma dev start default",
    "db:stop": "prisma dev stop default",
    "db:restart": "prisma dev stop default && prisma dev start default",
    "db:status": "prisma dev ls",
    "db:check": "node --env-file=.env scripts/check-db.mjs",
    "db:migrate": "prisma migrate dev",
    "db:supabase:schema": "node --env-file=.env scripts/supabase-migrate-deploy.mjs",
    "db:supabase:copy": "node --env-file=.env scripts/copy-db-to-supabase.mjs",
    "db:supabase:check": "node --env-file=.env scripts/check-supabase.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "scrape": "tsx scripts/scrape-help-center.ts",
    "extract-facts": "tsx scripts/extract-facts.ts",
    "generate-questions": "tsx scripts/generate-questions.ts",
    "publish-questions": "tsx scripts/publish-questions.ts",
    "import-articles": "tsx scripts/import-articles.ts",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.9.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "openai": "^6.45.0",
    "p-limit": "^7.3.0",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
